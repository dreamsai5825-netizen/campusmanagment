{
  "firestore": [
    {
      "database": "cms1",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "apphosting": [
    {
      "backendId": "campus-connect",
      "rootDir": ".",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        ".firebase",
        "e2e",
        "test-results",
        "playwright-report"
      ]
    }
  ]
}
